# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it. This file (.env.example) IS committed
# so anyone cloning the repo knows which variables exist.

# --- Django ---
DJANGO_SECRET_KEY=dev-insecure-key-change-me
DJANGO_DEBUG=True

# --- CORS / CSRF (comma-separated origins) ---
# Local dev default (http://localhost:3000,http://127.0.0.1:3000) is used
# automatically if these are left blank. In production, set to your real
# frontend origin(s), e.g. https://interviewx.dev
CORS_ALLOWED_ORIGINS=
CSRF_TRUSTED_ORIGINS=

# --- Production HTTPS (only takes effect when DJANGO_DEBUG=False) ---
# Leave as True for a normal HTTPS deploy. Set False only if you're
# intentionally serving over plain HTTP behind something else that redirects.
DJANGO_SECURE_SSL_REDIRECT=True

# --- Postgres (used by both the db container and the backend container) ---
POSTGRES_DB=aiis
POSTGRES_USER=aiis_user
POSTGRES_PASSWORD=aiis_pass

# --- JWT ---
# NOTE: must not be left blank. Docker Compose's env_file loading sets this
# as an actual (empty-string) environment variable rather than leaving it
# unset, so Django's os.environ.get("JWT_SECRET", SECRET_KEY) fallback never
# kicks in and token signing breaks with InvalidKeyError. Give it a real
# value even for local dev.
JWT_SECRET=dev-insecure-jwt-key-change-me

# --- OpenRouter (LLM interview engine) ---
# Get a key at https://openrouter.ai -> sign up -> create key.
# Without this, the app boots fine but /chat/ and /end/ calls will fail.
OPENROUTER_API_KEY=

# --- Razorpay (Phase 7 payments) ---
# Get test-mode keys at https://dashboard.razorpay.com -> Settings -> API Keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Email (OTP verification) ---
# Leave EMAIL_HOST blank to print OTP emails to the backend container logs
# instead of sending real email (fine for local dev).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=InterviewX <no-reply@interviewx.local>

# --- Google Sign-In ---
# OAuth "Web application" client ID from Google Cloud Console.
# Shared by frontend (renders button) and backend (verifies ID tokens).
GOOGLE_CLIENT_ID=